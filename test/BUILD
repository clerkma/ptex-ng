# Integration test targets
# These are declared for documentation purposes.
# Actual execution is via CI workflow steps (test/run.sh)
# because they require the full texmf tree and aptex binary in specific paths.
#
# Unit tests: blade test //test/unit/...
# Benchmark:  blade run //test/bench:bench_engine
# Smoke test: cd test && sh run.sh  (requires built aptex at src/aptex)
# Regression: cd test && sh regression/run.sh [--update]
# Trip test:  cd test && sh trip/run.sh
